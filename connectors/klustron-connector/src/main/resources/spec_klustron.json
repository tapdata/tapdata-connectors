{
  "properties": {
    "name": "KlustronDB",
    "realName": "KlustronDB",
    "icon": "icons/klustron.png",
    "doc": "${doc}",
    "id": "klustron",
    "tags": [
      "Database",
      "ssl",
      "doubleActive",
      "disableForeignKey",
      "NullsLast"
    ]
  },
  "configOptions": {
    "capabilities": [
      {
        "id": "dml_insert_policy",
        "alternatives": [
          "update_on_exists",
          "ignore_on_exists",
          "just_insert"
        ]
      },
      {
        "id": "dml_update_policy",
        "alternatives": [
          "ignore_on_nonexists",
          "insert_on_nonexists"
        ]
      },
      {
        "id": "api_server_supported"
      },
      {
        "id": "source_incremental_update_event_have_before"
      },
      {
        "id": "illegal_date_acceptable"
      },
      {
        "id": "batch_read_hash_split"
      },
      {
        "id": "source_support_exactly_once"
      }
    ],
    "supportDDL": {
      "events": [
        "new_field_event",
        "alter_field_name_event",
        "alter_field_attributes_event",
        "drop_field_event"
      ]
    },
    "monitorAPI": {
      "lowerCaseTableNames": {
        "title": "${lowerCaseTableNames}",
        "type": "string",
        "method": "io.tapdata.connector.mysql.MysqlConnector#getLowerCaseTableNames"
      }
    },
    "connection": {
      "type": "object",
      "properties": {
        "deploymentMode": {
          "type": "string",
          "title": "${deploymentMode}",
          "default": "standalone",
          "x-decorator": "FormItem",
          "x-component": "Select",
          "x-index": 1,
          "enum": [
            {
              "label": "${standalone}",
              "value": "standalone"
            },
            {
              "label": "${master-slave}",
              "value": "master-slave"
            }
          ],
          "x-reactions": [
            {
              "target": "*(host,port)",
              "fulfill": {
                "state": {
                  "visible": "{{$self.value === 'standalone'}}"
                }
              }
            },
            {
              "target": "*(masterSlaveAddress)",
              "fulfill": {
                "state": {
                  "visible": "{{$self.value === 'master-slave'}}"
                }
              }
            }
          ]
        },
        "computeNode": {
          "type": "array",
          "title": "${compute_node}",
          "x-decorator": "FormItem",
          "x-component": "ArrayTable",
          "x-index": 10,
          "required": true,
          "default": [
            {
              "host": "",
              "portMysql": null,
              "portPg": null
            }
          ],
          "items": {
            "type": "object",
            "properties": {
              "c1": {
                "type": "void",
                "x-component": "ArrayTable.Column",
                "x-index": 10,
                "x-component-props": {
                  "title": "${compute_host}"
                },
                "properties": {
                  "host": {
                    "type": "string",
                    "required": true,
                    "x-decorator": "FormItem",
                    "x-component": "Input"
                  }
                }
              },
              "c2": {
                "type": "void",
                "x-component": "ArrayTable.Column",
                "x-index": 20,
                "x-component-props": {
                  "title": "${port_mysql}"
                },
                "properties": {
                  "portMysql": {
                    "type": "string",
                    "required": true,
                    "x-component": "InputNumber",
                    "x-decorator": "FormItem",
                    "default": "string",
                    "x-component-props": {
                      "allowCreate": true,
                      "filterable": true
                    }
                  }
                }
              },
              "c3": {
                "type": "void",
                "x-component": "ArrayTable.Column",
                "x-index": 30,
                "x-component-props": {
                  "title": "${port_pg}"
                },
                "properties": {
                  "portPg": {
                    "type": "string",
                    "required": true,
                    "x-component": "InputNumber",
                    "x-decorator": "FormItem",
                    "default": "string",
                    "x-component-props": {
                      "allowCreate": true,
                      "filterable": true
                    }
                  }
                }
              },
              "c4": {
                "type": "void",
                "x-component": "ArrayTable.Column",
                "x-index": 40,
                "x-component-props": {
                  "title": "${df_table_field_operator}",
                  "prop": "operations",
                  "fixed": "right"
                },
                "properties": {
                  "operator": {
                    "type": "void",
                    "x-component": "FormItem",
                    "properties": {
                      "remove": {
                        "type": "void",
                        "x-component": "ArrayTable.Remove"
                      }
                    }
                  }
                }
              }
            }
          },
          "properties": {
            "add": {
              "type": "void",
              "x-component": "ArrayTable.Addition",
              "title": "${compute_add}"
            }
          }
        },
        "db": {
          "type": "string",
          "title": "${database}",
          "x-decorator": "FormItem",
          "x-component": "Input",
          "apiServerKey": "database_name",
          "x-decorator-props": {
            "tooltip": "${databaseTip}"
          },
          "default": "postgres",
          "x-index": 20,
          "required": true
        },
        "sc": {
          "type": "string",
          "title": "${database}",
          "x-decorator": "FormItem",
          "x-component": "Input",
          "apiServerKey": "database_name",
          "x-decorator-props": {
            "tooltip": "${databaseTip}"
          },
          "x-index": 30,
          "required": true
        },
        "username": {
          "type": "string",
          "title": "${username}",
          "x-decorator": "FormItem",
          "x-component": "Input",
          "apiServerKey": "database_username",
          "x-index": 40,
          "required": true
        },
        "password": {
          "type": "string",
          "title": "${password}",
          "x-decorator": "FormItem",
          "x-component": "Password",
          "apiServerKey": "database_password",
          "x-index": 50
        },
        "storageNode": {
          "type": "array",
          "title": "${storage_node}",
          "x-decorator": "FormItem",
          "x-component": "ArrayTable",
          "x-index": 60,
          "required": true,
          "default": [
            {
              "host": "",
              "port": null,
              "username": "",
              "password": ""
            }
          ],
          "items": {
            "type": "object",
            "properties": {
              "c1": {
                "type": "void",
                "x-component": "ArrayTable.Column",
                "x-index": 10,
                "x-component-props": {
                  "title": "${storage_host}"
                },
                "properties": {
                  "host": {
                    "type": "string",
                    "required": true,
                    "x-decorator": "FormItem",
                    "x-component": "Input"
                  }
                }
              },
              "c2": {
                "type": "void",
                "x-component": "ArrayTable.Column",
                "x-index": 20,
                "x-component-props": {
                  "title": "${storage_port}"
                },
                "properties": {
                  "port": {
                    "type": "string",
                    "required": true,
                    "x-component": "InputNumber",
                    "x-decorator": "FormItem",
                    "default": "string",
                    "x-component-props": {
                      "allowCreate": true,
                      "filterable": true
                    }
                  }
                }
              },
              "c3": {
                "type": "void",
                "x-component": "ArrayTable.Column",
                "x-index": 30,
                "x-component-props": {
                  "title": "${storage_username}"
                },
                "properties": {
                  "username": {
                    "type": "string",
                    "required": true,
                    "x-decorator": "FormItem",
                    "x-component": "Input"
                  }
                }
              },
              "c4": {
                "type": "void",
                "x-component": "ArrayTable.Column",
                "x-index": 40,
                "x-component-props": {
                  "title": "${storage_password}"
                },
                "properties": {
                  "password": {
                    "type": "string",
                    "required": true,
                    "x-decorator": "FormItem",
                    "x-component": "Password"
                  }
                }
              },
              "c5": {
                "type": "void",
                "x-component": "ArrayTable.Column",
                "x-index": 50,
                "x-component-props": {
                  "title": "${df_table_field_operator}",
                  "prop": "operations",
                  "fixed": "right"
                },
                "properties": {
                  "operator": {
                    "type": "void",
                    "x-component": "FormItem",
                    "properties": {
                      "remove": {
                        "type": "void",
                        "x-component": "ArrayTable.Remove"
                      }
                    }
                  }
                }
              }
            }
          },
          "properties": {
            "add": {
              "type": "void",
              "x-component": "ArrayTable.Addition",
              "title": "${storage_add}"
            }
          }
        },
        "OPTIONAL_FIELDS": {
          "type": "void",
          "properties": {
            "addtionalString": {
              "type": "string",
              "title": "${addtionalString}",
              "x-decorator": "FormItem",
              "x-component": "Input",
              "default": "useUnicode=yes&characterEncoding=UTF-8",
              "apiServerKey": "addtionalString",
              "x-decorator-props": {
                "tooltip": "${extParamsTip}"
              },
              "x-index": 100
            },
            "timezone": {
              "type": "string",
              "title": "${timezone}",
              "default": "",
              "x-decorator": "FormItem",
              "x-component": "Select",
              "x-decorator-props": {
                "tooltip": "${timezoneTip}"
              },
              "x-index": 110,
              "enum": [
                {
                  "label": "",
                  "value": ""
                },
                {
                  "label": "UTC -11",
                  "value": "-11:00"
                },
                {
                  "label": "UTC -10",
                  "value": "-10:00"
                },
                {
                  "label": "UTC -09",
                  "value": "-09:00"
                },
                {
                  "label": "UTC -08",
                  "value": "-08:00"
                },
                {
                  "label": "UTC -07",
                  "value": "-07:00"
                },
                {
                  "label": "UTC -06",
                  "value": "-06:00"
                },
                {
                  "label": "UTC -05",
                  "value": "-05:00"
                },
                {
                  "label": "UTC -04",
                  "value": "-04:00"
                },
                {
                  "label": "UTC -03",
                  "value": "-03:00"
                },
                {
                  "label": "UTC -02",
                  "value": "-02:00"
                },
                {
                  "label": "UTC -01",
                  "value": "-01:00"
                },
                {
                  "label": "UTC",
                  "value": "+00:00"
                },
                {
                  "label": "UTC +01",
                  "value": "+01:00"
                },
                {
                  "label": "UTC +02",
                  "value": "+02:00"
                },
                {
                  "label": "UTC +03",
                  "value": "+03:00"
                },
                {
                  "label": "UTC +04",
                  "value": "+04:00"
                },
                {
                  "label": "UTC +05",
                  "value": "+05:00"
                },
                {
                  "label": "UTC +06",
                  "value": "+06:00"
                },
                {
                  "label": "UTC +07",
                  "value": "+07:00"
                },
                {
                  "label": "UTC +08",
                  "value": "+08:00"
                },
                {
                  "label": "UTC +09",
                  "value": "+09:00"
                },
                {
                  "label": "UTC +10",
                  "value": "+10:00"
                },
                {
                  "label": "UTC +11",
                  "value": "+11:00"
                },
                {
                  "label": "UTC +12",
                  "value": "+12:00"
                },
                {
                  "label": "UTC +13",
                  "value": "+13:00"
                },
                {
                  "label": "UTC +14",
                  "value": "+14:00"
                }
              ]
            }
          }
        }
      }
    },
    "node": {
      "type": "object",
      "properties": {
        "materAble": {
          "type": "boolean",
          "title": "${materAble}",
          "default": false,
          "x-index": 10,
          "x-decorator": "FormItem",
          "x-component": "Switch",
          "x-decorator-props": {
            "tooltip": "${materAbleTip}"
          },
          "x-reactions": [
            {
              "dependencies": ["$inputs"],
              "fulfill": {
                "state": {
                  "display": "{{$deps[0].length > 0 ? \"visible\":\"hidden\"}}"
                }
              }
            }
          ]
        },
        "mateSql": {
          "type": "String",
          "title": "${mateSql}",
          "default": "",
          "x-index": 11,
          "x-decorator": "FormItem",
          "x-component": "TextArea",
          "x-reactions": [
            {
              "dependencies": ["$inputs"],
              "fulfill": {
                "state": {
                  "display": "{{$deps[0].length > 0 ? \"visible\":\"hidden\"}}"
                }
              }
            }
          ]
        },
        "createAutoInc": {
          "type": "boolean",
          "title": "${createAutoInc}",
          "default": false,
          "x-index": 20,
          "x-decorator": "FormItem",
          "x-component": "Switch",
          "x-decorator-props": {
            "tooltip": "${createAutoIncTooltip}"
          },
          "x-reactions": [
            {
              "dependencies": [
                "$inputs"
              ],
              "fulfill": {
                "state": {
                  "display": "{{$deps[0].length > 0 ? \"visible\":\"hidden\"}}"
                }
              }
            }
          ]
        },
        "autoIncJumpValue": {
          "required": true,
          "type": "string",
          "title": "${autoIncJumpValue}",
          "default": 1000000,
          "x-index": 30,
          "x-decorator": "FormItem",
          "x-component": "InputNumber",
          "x-reactions": [
            {
              "dependencies": [
                "$inputs",
                ".createAutoInc"
              ],
              "fulfill": {
                "state": {
                  "display": "{{$deps[0].length > 0 && $deps[1] ? \"visible\":\"hidden\"}}"
                }
              }
            }
          ]
        },
        "applyDefault": {
          "type": "boolean",
          "title": "${applyDefault}",
          "default": false,
          "x-index": 40,
          "x-decorator": "FormItem",
          "x-component": "Switch",
          "x-decorator-props": {
            "tooltip": "${applyDefaultTooltip}"
          },
          "x-reactions": [
            {
              "dependencies": [
                "$inputs"
              ],
              "fulfill": {
                "state": {
                  "display": "{{$deps[0].length > 0 ? \"visible\":\"hidden\"}}"
                }
              }
            }
          ]
        },
        "hashSplit": {
          "type": "boolean",
          "title": "${hashSplit}",
          "default": false,
          "x-index": 50,
          "x-decorator": "FormItem",
          "x-component": "Switch",
          "x-decorator-props": {
            "tooltip": "${hashSplitTooltip}"
          },
          "x-reactions": [
            {
              "dependencies": [
                "$inputs"
              ],
              "fulfill": {
                "state": {
                  "display": "{{!$deps[0].length ? \"visible\":\"hidden\"}}"
                }
              }
            }
          ]
        },
        "maxSplit": {
          "required": true,
          "type": "string",
          "title": "${maxSplit}",
          "default": 20,
          "x-index": 60,
          "x-decorator": "FormItem",
          "x-component": "InputNumber",
          "x-component-props": {
            "min": 2,
            "max": 10000
          },
          "x-reactions": [
            {
              "dependencies": [
                "$inputs",
                ".hashSplit"
              ],
              "fulfill": {
                "state": {
                  "display": "{{!$deps[0].length && $deps[1] ? \"visible\":\"hidden\"}}"
                }
              }
            }
          ]
        },
        "batchReadThreadSize": {
          "required": true,
          "type": "string",
          "title": "${batchReadThreadSize}",
          "default": 4,
          "x-index": 70,
          "x-decorator": "FormItem",
          "x-component": "InputNumber",
          "x-component-props": {
            "min": 1,
            "max": 16
          },
          "x-reactions": [
            {
              "dependencies": [
                "$inputs",
                ".hashSplit"
              ],
              "fulfill": {
                "state": {
                  "display": "{{!$deps[0].length && $deps[1] ? \"visible\":\"hidden\"}}"
                }
              }
            }
          ]
        },
        "maximumQueueSize": {
          "type": "string",
          "title": "${maximumQueueSize}",
          "default": 800,
          "x-index": 80,
          "x-decorator": "FormItem",
          "x-component": "InputNumber",
          "x-decorator-props": {
            "tooltip": "${maximumQueueSizeTip}"
          },
          "x-reactions": [
            {
              "dependencies": [
                "$inputs"
              ],
              "fulfill": {
                "state": {
                  "display": "{{!$deps[0].length ? \"visible\":\"hidden\"}}"
                }
              }
            }
          ]
        }
      }
    }
  },
