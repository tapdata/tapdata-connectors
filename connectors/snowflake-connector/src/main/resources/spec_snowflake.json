{
  "properties": {
    "name": "Snowflake",
    "realName": "Snowflake",
    "icon": "icons/snowflake.png",
    "doc": "${doc}",
    "id": "snowflake",
    "tags": ["Database", "Cloud", "DataWarehouse"]
  },
  "configOptions": {
    "capabilities": [
      {
        "id": "dml_insert_policy",
        "alternatives": ["update_on_exists", "ignore_on_exists", "just_insert"]
      },
      {
        "id": "dml_update_policy",
        "alternatives": ["ignore_on_nonexists", "insert_on_nonexists", "log_on_nonexists"]
      },
      {
        "id": "dml_delete_policy",
        "alternatives": ["ignore_on_nonexists", "log_on_nonexists"]
      },
      {
        "id": "api_server_supported"
      }
    ],
    "connection": {
      "type": "object",
      "properties": {
        "account": {
          "type": "string",
          "title": "${account}",
          "x-decorator": "FormItem",
          "x-component": "Input",
          "apiServerKey": "database_host",
          "x-index": 1,
          "required": true
        },
        "user": {
          "type": "string",
          "title": "${user}",
          "x-decorator": "FormItem",
          "x-component": "Input",
          "apiServerKey": "database_username",
          "x-index": 2,
          "required": true
        },
        "authMethod": {
          "type": "string",
          "title": "${authMethod}",
          "default": "password",
          "x-decorator": "FormItem",
          "x-component": "Select",
          "x-index": 3,
          "enum": [
            {
              "label": "${authMethodPassword}",
              "value": "password"
            },
            {
              "label": "${authMethodPat}",
              "value": "pat"
            },
            {
              "label": "${authMethodKeyPair}",
              "value": "keyPair"
            }
          ]
        },
        "password": {
          "type": "string",
          "title": "${password}",
          "x-decorator": "FormItem",
          "x-component": "Password",
          "apiServerKey": "database_password",
          "x-index": 4,
          "x-reactions": {
            "dependencies": ["authMethod"],
            "fulfill": {
              "state": {
                "visible": "{{$deps[0]==='password'}}",
                "required": "{{$deps[0]==='password'}}"
              }
            }
          }
        },
        "patToken": {
          "type": "string",
          "title": "${patToken}",
          "x-decorator": "FormItem",
          "x-component": "Password",
          "x-index": 5,
          "x-reactions": {
            "dependencies": ["authMethod"],
            "fulfill": {
              "state": {
                "visible": "{{$deps[0]==='pat'}}",
                "required": "{{$deps[0]==='pat'}}"
              }
            }
          }
        },
        "privateKey": {
          "type": "string",
          "title": "${privateKey}",
          "x-decorator": "FormItem",
          "x-component": "TextFileReader",
          "fileNameField": "privateKeyFile",
          "x-index": 6,
          "x-reactions": {
            "dependencies": ["authMethod"],
            "fulfill": {
              "state": {
                "visible": "{{$deps[0]==='keyPair'}}",
                "required": "{{$deps[0]==='keyPair'}}"
              }
            }
          }
        },
        "privateKeyPassword": {
          "type": "string",
          "title": "${privateKeyPassword}",
          "x-decorator": "FormItem",
          "x-component": "Password",
          "x-index": 7,
          "x-reactions": {
            "dependencies": ["authMethod"],
            "fulfill": {
              "state": {
                "visible": "{{$deps[0]==='keyPair'}}"
              }
            }
          }
        },
        "warehouse": {
          "type": "string",
          "title": "${warehouse}",
          "x-decorator": "FormItem",
          "x-component": "Input",
          "x-index": 8,
          "required": true
        },
        "database": {
          "type": "string",
          "title": "${database}",
          "x-decorator": "FormItem",
          "x-component": "Input",
          "apiServerKey": "database_name",
          "x-index": 9,
          "required": true
        },
        "schema": {
          "type": "string",
          "title": "${schema}",
          "default": "PUBLIC",
          "x-decorator": "FormItem",
          "x-component": "Input",
          "apiServerKey": "database_owner",
          "x-index": 10,
          "required": true
        },
        "role": {
          "type": "string",
          "title": "${role}",
          "x-decorator": "FormItem",
          "x-component": "Input",
          "x-index": 11
        },
        "timezone": {
          "type": "string",
          "title": "${timezone}",
          "default": "+00:00",
          "x-decorator": "FormItem",
          "x-component": "Select",
          "x-index": 12,
          "enum": [
            {
              "label": "UTC -11",
              "value": "-11:00"
            },
            {
              "label": "UTC -10",
              "value": "-10:00"
            },
            {
              "label": "UTC -09",
              "value": "-09:00"
            },
            {
              "label": "UTC -08",
              "value": "-08:00"
            },
            {
              "label": "UTC -07",
              "value": "-07:00"
            },
            {
              "label": "UTC -06",
              "value": "-06:00"
            },
            {
              "label": "UTC -05",
              "value": "-05:00"
            },
            {
              "label": "UTC -04",
              "value": "-04:00"
            },
            {
              "label": "UTC -03",
              "value": "-03:00"
            },
            {
              "label": "UTC -02",
              "value": "-02:00"
            },
            {
              "label": "UTC -01",
              "value": "-01:00"
            },
            {
              "label": "UTC",
              "value": "+00:00"
            },
            {
              "label": "UTC +01",
              "value": "+01:00"
            },
            {
              "label": "UTC +02",
              "value": "+02:00"
            },
            {
              "label": "UTC +03",
              "value": "+03:00"
            },
            {
              "label": "UTC +04",
              "value": "+04:00"
            },
            {
              "label": "UTC +05",
              "value": "+05:00"
            },
            {
              "label": "UTC +06",
              "value": "+06:00"
            },
            {
              "label": "UTC +07",
              "value": "+07:00"
            },
            {
              "label": "UTC +08",
              "value": "+08:00"
            }
          ]
        }
      }
    },
    "node": {
      "type": "object",
      "x-tableConfigScope": ["target"],
      "properties": {
        "tableType": {
          "type": "string",
          "title": "${tableType}",
          "default": "STANDARD",
          "x-index": 1,
          "x-perTable": true,
          "x-decorator": "FormItem",
          "x-component": "Select",
          "x-decorator-props": {
            "tooltip": "${tableTypeTooltip}"
          },
          "enum": [
            {
              "label": "${tableTypeStandard}",
              "value": "STANDARD"
            },
            {
              "label": "${tableTypeHybrid}",
              "value": "HYBRID"
            },
            {
              "label": "${tableTypeDynamic}",
              "value": "DYNAMIC"
            }
          ],
          "x-reactions": [
            {
              "dependencies": ["$inputs"],
              "fulfill": {
                "state": {
                  "display": "{{$deps[0].length > 0 ? \"visible\":\"hidden\"}}"
                }
              }
            }
          ]
        },
        "dynamicTableLag": {
          "type": "string",
          "title": "${dynamicTableLag}",
          "default": "1 minute",
          "x-index": 2,
          "x-perTable": true,
          "x-decorator": "FormItem",
          "x-component": "Input",
          "x-decorator-props": {
            "tooltip": "${dynamicTableLagTooltip}"
          },
          "x-reactions": [
            {
              "dependencies": [".tableType"],
              "fulfill": {
                "state": {
                  "visible": "{{$deps[0]==='DYNAMIC'}}"
                }
              }
            }
          ]
        },
        "dynamicTableQuery": {
          "type": "string",
          "title": "${dynamicTableQuery}",
          "x-index": 3,
          "x-perTable": true,
          "x-decorator": "FormItem",
          "x-component": "Input.TextArea",
          "x-decorator-props": {
            "tooltip": "${dynamicTableQueryTooltip}"
          },
          "x-reactions": [
            {
              "dependencies": [".tableType"],
              "fulfill": {
                "state": {
                  "visible": "{{$deps[0]==='DYNAMIC'}}"
                }
              }
            }
          ]
        }
      }
    }
  },
  "messages": {
    "default": "en_US",
    "en_US": {
      "doc": "docs/snowflake_en_US.md",
      "account": "Account",
      "user": "User",
      "password": "Password",
      "authMethod": "Authentication Method",
      "authMethodPassword": "Password",
      "authMethodPat": "PAT Token",
      "authMethodKeyPair": "Key Pair",
      "patToken": "PAT Token",
      "privateKey": "Private Key",
      "privateKeyPassword": "Private Key Password",
      "warehouse": "Warehouse",
      "database": "Database",
      "schema": "Schema",
      "role": "Role",
      "timezone": "Timezone",
      "tableType": "Table Type",
      "tableTypeTooltip": "The table type used when creating the target table. Hybrid tables require a primary key and support secondary indexes; Dynamic tables require a target lag and a query.",
      "tableTypeStandard": "Standard Table",
      "tableTypeHybrid": "Hybrid Table",
      "tableTypeDynamic": "Dynamic Table",
      "dynamicTableLag": "Target Lag",
      "dynamicTableLagTooltip": "The target lag for the dynamic table, for example: '1 minute' or 'DOWNSTREAM'",
      "dynamicTableQuery": "Dynamic Table Query",
      "dynamicTableQueryTooltip": "The AS SELECT query used to define the dynamic table content"
    },
    "zh_CN": {
      "doc": "docs/snowflake_zh_CN.md",
      "account": "账户",
