      "authMethodKeyPair": "密钥对",
      "patToken": "PAT 令牌",
      "privateKey": "私钥",
      "privateKeyPassword": "私钥密码",
      "warehouse": "仓库",
      "database": "数据库",
      "schema": "模式",
