      "tableTypeDynamic": "动态表",
      "dynamicTableLag": "目标延迟",
      "dynamicTableLagTooltip": "动态表的目标延迟，例如：'1 minute' 或 'DOWNSTREAM'",
      "dynamicTableQuery": "动态表查询",
      "dynamicTableQueryTooltip": "用于定义动态表内容的 AS SELECT 查询语句"
    },
    "zh_TW": {
      "doc": "docs/snowflake_zh_TW.md",
      "account": "賬戶",
      "user": "用戶名",
      "password": "密碼",
      "authMethod": "認證方式",
      "authMethodPassword": "普通密碼",
      "authMethodPat": "PAT 令牌",
      "authMethodKeyPair": "密鑰對",
      "patToken": "PAT 令牌",
      "privateKey": "私鑰",
      "privateKeyPassword": "私鑰密碼",
